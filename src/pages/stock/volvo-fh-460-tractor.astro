                </div>
                <div class="mt-4 pt-3 border-t border-line text-center">
                  <div class="text-[13px] text-muted">Buy</div>
                  {s.oldPrice && s.oldPrice > s.price && (
                    <div class="text-[12.5px] text-muted line-through tabular-nums">
                      AED {fmt(s.oldPrice)}
                    </div>
                  )}
                  <div class="font-display text-[20px] font-bold text-ink leading-none tabular-nums mt-0.5">
                    AED {fmt(s.price)}
