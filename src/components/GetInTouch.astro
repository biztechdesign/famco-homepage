---
import { Icon } from "astro-icon/components";
import { asset, link } from "@/lib/asset";
---

<section class="bg-white">
  <div class="container py-6 lg:py-8">
    <div class="img-skeleton relative rounded-2xl overflow-hidden bg-charcoal min-h-[360px] lg:min-h-[500px]">
      <img
        src={asset("/placeholders/panorama-focus-hand-holding-headset-600nw-2296039729.webp")}
        alt="FAMCO specialists on a customer call"
        class="absolute inset-0 h-full w-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-charcoal-900 via-charcoal-800/70 to-transparent"></div>

      <div class="relative grid lg:grid-cols-2">
        <div class="relative text-white p-8 lg:p-14 flex flex-col justify-between lg:justify-center min-h-[360px] lg:min-h-[500px]">
          <h2 class="font-display font-bold uppercase tracking-tight leading-[0.95] text-3xl sm:text-4xl lg:text-5xl mb-0 lg:mb-7 whitespace-nowrap">
            Get in <span class="text-secondary-300">touch.</span>
          </h2>

          <div class="flex flex-col sm:flex-row gap-3">
            <a
              href="tel:80032626"
              class="btn btn-primary h-12 px-5 text-[14px] rounded-md inline-flex items-center justify-center gap-2"
            >
              <Icon name="lucide:phone" class="h-4 w-4" />
              Call 800 32626
            </a>

            <a
              href={link("/stock")}
              class="inline-flex items-center justify-center gap-2 h-12 px-5 text-[14px] font-semibold rounded-md border border-white/30 text-white hover:bg-white/10 hover:border-white/60 transition-colors"
            >
              <Icon name="lucide:message-circle" class="h-4 w-4" />
              WhatsApp us
            </a>

            <a
              href="mailto:FAMCO@alfuttaim.ae"
              class="inline-flex items-center justify-center gap-2 h-12 px-5 text-[14px] font-semibold rounded-md border border-white/30 text-white hover:bg-white/10 hover:border-white/60 transition-colors"
            >
              <Icon name="lucide:mail" class="h-4 w-4" />
              Email us
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
