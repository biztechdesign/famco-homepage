---
import { Icon } from "astro-icon/components";
import { asset, link } from "@/lib/asset";

const ITEMS = [
  { title: "Sell your truck", href: "/stock?category=sell&type=truck", image: "/placeholders/6ca58478-2dde-4b73-b8bd-931d9533de0c.webp" },
  { title: "Sell your bus or van", href: "/stock?category=sell&type=bus", image: "/placeholders/dubai-global-village-bus.jpg" },
  { title: "Sell your machine", href: "/stock?category=sell&type=machine", image: "/placeholders/cat-construction.jpg" },
  { title: "Sell your forklift", href: "/stock?category=sell&type=forklift", image: "/hero/inspected.jpg" },
];
---

<section class="bg-white">
  <div class="container py-12 lg:py-16">
    <div class="flex items-end justify-between gap-4 mb-6 lg:mb-8">
      <div>
        <h2 class="font-display text-3xl lg:text-4xl font-bold text-ink">
          Sell your current vehicle or <span class="text-secondary">machine</span>
        </h2>
      </div>

      <div class="hidden sm:flex items-center gap-2 shrink-0">
        <button
          data-sell-prev
          aria-label="Previous"
          class="h-11 w-11 rounded-full border border-line bg-white flex items-center justify-center text-ink hover:text-secondary hover:border-secondary transition-colors"
        >
          <Icon name="lucide:chevron-left" class="h-5 w-5" />
        </button>
        <button
          data-sell-next
          aria-label="Next"
          class="h-11 w-11 rounded-full border border-line bg-white flex items-center justify-center text-ink hover:text-secondary hover:border-secondary transition-colors"
        >
          <Icon name="lucide:chevron-right" class="h-5 w-5" />
        </button>
      </div>
    </div>

    <div
      data-sell-track
      class="flex gap-5 overflow-x-auto scrollbar-hide snap-x snap-mandatory pb-2"
    >
      {ITEMS.map((it) => (
        <a
          href={link(it.href)}
          data-card
          class="group relative shrink-0 w-[78%] sm:w-[48%] lg:w-[calc((100%-2.5rem)/3)] aspect-[4/3] rounded-2xl overflow-hidden bg-charcoal snap-start transition-all duration-300 hover:shadow-lift hover:-translate-y-0.5"
        >
          <img
            src={asset(it.image)}
            alt={it.title}
            class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-charcoal-900/85 via-charcoal-900/15 to-transparent"></div>

          <div class="absolute bottom-0 left-0 right-0 p-5 lg:p-6 flex items-end justify-between gap-3">
            <h3 class="font-display text-xl lg:text-2xl font-bold text-white leading-tight">
              {it.title}
            </h3>
            <span
              aria-hidden="true"
              class="h-9 w-9 rounded-full bg-secondary text-ink flex items-center justify-center shrink-0 transition-all duration-200 group-hover:bg-white group-hover:text-primary group-hover:scale-110"
            >
              <Icon name="lucide:chevron-right" class="h-5 w-5" />
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<script>
  const track = document.querySelector<HTMLDivElement>("[data-sell-track]");
  const prev = document.querySelector<HTMLButtonElement>("[data-sell-prev]");
  const next = document.querySelector<HTMLButtonElement>("[data-sell-next]");
  const scroll = (dir: 1 | -1) => {
    if (!track) return;
    const card = track.querySelector<HTMLElement>("[data-card]");
    const step = card?.offsetWidth ? card.offsetWidth + 20 : 360;
    track.scrollBy({ left: dir * step, behavior: "smooth" });
  };
  prev?.addEventListener("click", () => scroll(-1));
  next?.addEventListener("click", () => scroll(1));
</script>
