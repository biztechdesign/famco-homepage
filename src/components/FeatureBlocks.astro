---
import { Icon } from "astro-icon/components";
import { asset, link } from "@/lib/asset";

const cards = [
  {
    titleHtml: `Trade <span class="text-secondary-300">in</span>.<br />Trade <span class="text-secondary-300">up</span>.`,
    cta: "Get my trade-in value",
    href: link("/stock?category=sell"),
    bgImage: "/hero/trade-in.png",
  },
  {
    titleHtml: `Finance <span class="text-secondary-300">approved</span>.<br />Ready to <span class="text-secondary-300">roll</span>.`,
    cta: "See finance options",
    href: link("/stock"),
    bgImage: "/hero/finance.png",
  },
];
---

<section class="bg-white">
  <div class="container py-6 lg:py-8">
    <div class="grid gap-4 lg:gap-5 lg:grid-cols-2">
      {cards.map((c) => (
        <a
          href={c.href}
          class="group relative overflow-hidden rounded-2xl bg-charcoal text-white p-8 lg:p-12 min-h-[320px] lg:min-h-[400px] flex flex-col justify-between transition-all duration-300 hover:shadow-lift hover:-translate-y-0.5"
        >
          <img
            src={asset(c.bgImage)}
            alt=""
            aria-hidden="true"
            class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
          />
          <div class="absolute inset-0 bg-gradient-to-r from-charcoal-900 via-charcoal-800/70 to-transparent"></div>

          <div class="relative">
            <h2
              class="font-display font-bold uppercase tracking-tight leading-[0.95] text-3xl sm:text-4xl lg:text-5xl"
              set:html={c.titleHtml}
            />
          </div>

          <div class="relative mt-8">
            <span class="inline-flex items-center gap-2 btn btn-primary h-11 px-5 text-[14px] rounded-md">
              {c.cta}
              <Icon name="lucide:arrow-right" class="h-4 w-4 group-hover:translate-x-1 transition-transform" />
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
