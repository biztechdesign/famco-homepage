---
import { Icon } from "astro-icon/components";
import { asset, link } from "@/lib/asset";
---

<section class="bg-white">
  <div class="container py-6 lg:py-8">
    <div class="img-skeleton relative rounded-2xl overflow-hidden bg-charcoal min-h-[312px] lg:min-h-[500px]">
      <img
        src={asset("/placeholders/DVI-video-inspection.webp")}
        alt="FAMCO digital video inspection — buyer reviewing a truck on a live mobile call"
        class="absolute inset-0 h-full w-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-charcoal-900 via-charcoal-800/70 to-transparent"></div>

      <div class="relative grid lg:grid-cols-2">
        <div class="relative text-white p-7 lg:p-10 flex flex-col justify-between lg:justify-center min-h-[312px] lg:min-h-[500px]">
          <h2 class="font-display font-bold uppercase tracking-tight leading-[0.95] text-2xl sm:text-3xl lg:text-4xl mb-0 lg:mb-6 whitespace-nowrap">
            Live video <span class="text-secondary-300">inspection.</span>
          </h2>

          <a
            href={link("/stock/volvo-fh-460-tractor")}
            class="group/cta inline-flex items-center gap-2 btn btn-primary h-12 px-6 text-[14px] rounded-lg w-fit shadow-lift"
          >
            <Icon name="lucide:video" class="h-4 w-4" />
            Schedule a call
            <Icon name="lucide:arrow-right" class="h-4 w-4 group-hover/cta:translate-x-1 transition-transform" />
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
