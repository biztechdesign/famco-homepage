---
import { Icon } from "astro-icon/components";
import { asset, link } from "@/lib/asset";

const COLS = [
  { title: "Inventory", links: [
    { label: "View all stock", href: "/stock" },
    { label: "Trucks", href: "/stock?category=trucks" },
    { label: "Buses", href: "/stock?category=buses" },
    { label: "Construction equipment", href: "/stock?category=construction" },
    { label: "Material handling", href: "/stock?category=material-handling" },
    { label: "Power & industrial", href: "/stock?category=power" },
  ]},
  { title: "Buy & sell", links: [
    { label: "How to buy", href: "/stock" },
    { label: "0% interest finance", href: "/stock/volvo-fh-460-tractor#finance" },
    { label: "Trade in & trade up", href: "/stock?category=sell" },
    { label: "Get free valuation", href: "/stock?category=sell" },
    { label: "Live video inspection", href: "/stock/volvo-fh-460-tractor" },
  ]},
  { title: "Service", links: [
    { label: "TMH Workshop", href: "#" },
    { label: "Genuine parts", href: "#" },
    { label: "Book a service slot", href: "#" },
    { label: "GCC delivery", href: "#" },
    { label: "Customer support", href: "#" },
  ]},
  { title: "Company", links: [
    { label: "About Al-Futtaim Famco", href: "#" },
    { label: "Al-Futtaim Group", href: "#" },
    { label: "News & articles", href: "#" },
    { label: "Careers", href: "#" },
    { label: "Ethics & compliance", href: "#" },
  ]},
];

// Country list (used for the legend chip strip below the map).
const COUNTRIES = [
  { code: "KSA",     label: "Saudi Arabia", flag: "sa" },
  { code: "Bahrain", label: "Bahrain",      flag: "bh" },
  { code: "Qatar",   label: "Qatar",        flag: "qa" },
  { code: "UAE",     label: "United Arab Emirates", flag: "ae" },
] as const;

// Pins are positioned by % of the FULL section width/height, tuned
// against the Doha-centred zoom-6 iframe (which sits in the right
// 58 % of the section). Each cluster is constrained to its country's
// actual landmass so no pin floats over the Persian Gulf.
const PINS = [
  // ── Saudi Arabia (eastern part is visible — west edge of the iframe view)
  { country: "KSA",     left: "50%", top: "32%", icon: "/icons/category/big-truck.svg" },
  { country: "KSA",     left: "53%", top: "48%", icon: "/icons/category/_construction-equipment.svg" },
  { country: "KSA",     left: "56%", top: "65%", icon: "/icons/category/loader.svg" },
  // ── Bahrain (small island — single pin keeps it readable)
  { country: "Bahrain", left: "63%", top: "40%", icon: "/icons/category/van.svg" },
  // ── Qatar (peninsula immediately east of Bahrain)
  { country: "Qatar",   left: "66%", top: "44%", icon: "/icons/category/tipper.svg" },
  { country: "Qatar",   left: "65%", top: "50%", icon: "/icons/category/_construction-equipment.svg" },
  // ── UAE (eastern Gulf coast — right portion of the map)
  { country: "UAE",     left: "76%", top: "62%", icon: "/icons/category/big-truck.svg" },
  { country: "UAE",     left: "82%", top: "65%", icon: "/icons/category/tipper.svg" },
  { country: "UAE",     left: "88%", top: "62%", icon: "/icons/category/_construction-equipment.svg" },
];

const SOCIALS = ["lucide:linkedin", "lucide:facebook", "lucide:instagram", "lucide:youtube"] as const;
---

<footer class="bg-charcoal text-white">
  {/* ─── Branch network — full-bleed charcoal section, map on the right ─── */}
  <section class="relative border-b border-white/10 bg-charcoal overflow-hidden">
    {/* Map sits only on the right ~58% of the section. Its left edge is
        masked into transparent so the dark charcoal seamlessly bleeds
        into the map — no visible vertical seam. */}
    <div class="absolute inset-y-0 right-0 left-0 lg:left-[42%] pointer-events-none">
      <iframe
        title="Al-Futtaim Famco yards across UAE, Saudi Arabia, Qatar and Bahrain"
        src="https://maps.google.com/maps?q=Doha,Qatar&t=&z=6&ie=UTF8&iwloc=&output=embed"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        allowfullscreen
        class="absolute inset-0 h-full w-full border-0 grayscale contrast-110 opacity-55"
        style="mask-image:linear-gradient(to right,transparent 0%,rgba(0,0,0,0.4) 25%,black 60%,black 100%);-webkit-mask-image:linear-gradient(to right,transparent 0%,rgba(0,0,0,0.4) 25%,black 60%,black 100%);"
      ></iframe>

      {/* Soft warm glow on the right side for brand colour */}
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_70%_60%_at_85%_45%,rgba(255,209,0,0.18),transparent_70%)]"></div>
      {/* Bottom-right vignette for depth */}
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_60%_at_95%_95%,rgba(8,8,11,0.40),transparent_60%)]"></div>
    </div>

    {/* Pin layer — full-bleed over the section so each pin's % position
        is in section coords (left:50% = the visual centre). Pins are
        clustered inside their country's landmass on the locked map view. */}
    <div class="absolute inset-0 hidden lg:block pointer-events-none">
      {PINS.map((p) => (
        <span
          aria-hidden="true"
          class="pointer-events-auto absolute -translate-x-1/2 -translate-y-1/2 inline-flex h-12 w-12 rounded-2xl bg-white items-center justify-center ring-2 ring-secondary/55 shadow-[0_10px_24px_rgba(8,8,11,0.55)] transition-transform hover:scale-110"
          style={`left:${p.left};top:${p.top};`}
        >
          <span
            aria-hidden="true"
            class="block h-7 w-7 bg-charcoal-900"
            style={`-webkit-mask: url(${asset(p.icon)}) center / contain no-repeat; mask: url(${asset(p.icon)}) center / contain no-repeat;`}
          />
        </span>
      ))}
    </div>

    {/* Container-aligned content layer — heading + CTAs on the left only */}
    <div class="relative container">
      <div class="grid lg:grid-cols-2 min-h-[640px] lg:min-h-[720px]">
        <div class="py-16 lg:py-20 flex flex-col justify-center text-white">
          <h3 class="font-display text-3xl lg:text-5xl font-bold leading-[1.05] tracking-tight">
            Yards across the <span class="text-secondary-300">GCC</span>.
            <br />Picked by <span class="text-secondary-300">category</span>.
          </h3>

          <div class="mt-8 flex flex-wrap gap-3">
            <a
              href={link("/stock")}
              class="inline-flex items-center gap-2 btn btn-primary h-12 px-5 text-[14px] rounded-md"
            >
              View all stock
              <Icon name="lucide:arrow-right" class="h-4 w-4" />
            </a>
            <a
              href="tel:80032626"
              class="inline-flex items-center gap-2 h-12 px-5 rounded-md border border-white/15 bg-white/5 hover:bg-white/10 text-white text-[14px] font-semibold transition-colors"
            >
              <Icon name="lucide:phone" class="h-4 w-4 text-secondary-300" />
              800 32626
            </a>
          </div>

          {/* Country legend — chips matching the 4 countries on the map */}
          <ul class="mt-8 flex flex-wrap gap-2">
            {COUNTRIES.map((c) => (
              <li class="inline-flex items-center gap-2 h-8 px-3 rounded-full bg-white/5 border border-white/10 text-[12px] font-semibold">
                <span aria-hidden="true" class={`fi fi-${c.flag} rounded-sm`} style="width:1.1em;height:0.85em"></span>
                {c.label}
              </li>
            ))}
          </ul>
        </div>

        {/* Right cell intentionally empty — the map fills the right
            side of the section through the absolute layer above. */}
        <div class="hidden lg:block"></div>
      </div>
    </div>

    {/* Mobile fallback — map shown as a self-contained card under the heading */}
    <div class="lg:hidden relative z-10 container py-8">
      <div class="relative h-[320px] rounded-2xl bg-charcoal-900 overflow-hidden ring-1 ring-white/10">
        <iframe
          title="Al-Futtaim Famco yards"
          src="https://maps.google.com/maps?q=Doha,Qatar&t=&z=6&ie=UTF8&iwloc=&output=embed"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen
          class="absolute inset-0 h-full w-full border-0 grayscale contrast-110 opacity-60 pointer-events-none"
        ></iframe>
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_70%_60%_at_50%_50%,rgba(255,209,0,0.15),transparent_70%)] pointer-events-none"></div>
      </div>
    </div>
  </section>

  <div class="border-b border-white/10">
    <div class="container py-10 lg:py-12">
      <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
        <div>
          <h3 class="font-display text-2xl lg:text-3xl font-bold leading-tight">
            Subscribe for latest stock<br class="hidden sm:block" />
            and offers
          </h3>
        </div>

        <form action="#" method="post" class="flex w-full lg:w-auto lg:min-w-[440px] gap-2">
          <input
            type="email"
            required
            placeholder="Enter your email"
            aria-label="Email address"
            class="flex-1 h-12 px-4 rounded-md bg-white/5 border border-white/15 text-[14px] text-white placeholder:text-white/40 outline-none focus:border-secondary focus:bg-white/10 transition-colors"
          />
          <button
            type="submit"
            class="btn btn-primary h-12 px-5 text-[14px] rounded-md whitespace-nowrap"
          >
            Subscribe
            <Icon name="lucide:arrow-right" class="h-4 w-4" />
          </button>
        </form>
      </div>
    </div>
  </div>

  <div class="container py-12 lg:py-16">
    <div class="grid lg:grid-cols-[1.5fr_repeat(4,minmax(0,1fr))] gap-10 lg:gap-12">
      <div>
        <a href={link("/")} class="inline-flex items-center mb-5">
          <img
            src={asset("/brand/logo.png")}
            alt="Al-Futtaim FAMCO Used Equipment"
            class="h-16 w-auto brightness-0 invert"
          />
        </a>
        <p class="text-[13.5px] text-white/65 leading-relaxed mb-6 max-w-sm">
          Part of Al-Futtaim Group · UAE · 2026. Sole Volvo distributor —
          inspected used trucks, buses and machinery, delivered across the GCC.
        </p>

        <div class="space-y-2.5">
          <a
            href="tel:80032626"
            class="flex items-center gap-2.5 text-[13.5px] text-white/80 hover:text-secondary-300 transition-colors"
          >
            <span class="h-7 w-7 rounded-md bg-white/10 flex items-center justify-center shrink-0">
              <Icon name="lucide:phone" class="h-3.5 w-3.5" />
            </span>
            800 32626
          </a>
          <a
            href="mailto:FAMCO@alfuttaim.ae"
            class="flex items-center gap-2.5 text-[13.5px] text-white/80 hover:text-secondary-300 transition-colors"
          >
            <span class="h-7 w-7 rounded-md bg-white/10 flex items-center justify-center shrink-0">
              <Icon name="lucide:mail" class="h-3.5 w-3.5" />
            </span>
            FAMCO@alfuttaim.ae
          </a>
        </div>
      </div>

      {COLS.map((c) => (
        <div>
          <h4 class="text-[11px] uppercase tracking-[0.18em] font-bold text-white mb-4">
            {c.title}
          </h4>
          <ul class="space-y-2.5">
            {c.links.map((l) => (
              <li>
                <a
                  href={link(l.href)}
                  class="text-[13.5px] text-white/65 hover:text-secondary-300 transition-colors"
                >
                  {l.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>

  <div class="border-t border-white/10 bg-charcoal-800">
    <div class="container py-5 flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
      <div class="flex items-center gap-2">
        {SOCIALS.map((iconName) => (
          <a
            href="#"
            aria-label="Social link"
            class="h-9 w-9 rounded-md bg-white/5 border border-white/10 hover:bg-secondary hover:border-secondary flex items-center justify-center transition-colors"
          >
            <Icon name={iconName} class="h-4 w-4" />
          </a>
        ))}
      </div>

      <div class="flex flex-wrap items-center gap-x-5 gap-y-1.5 text-[12.5px] text-white/60">
        <span>© 2026 Al-Futtaim Auto &amp; Machinery Co. LLC</span>
        <a href="#" class="hover:text-white">Privacy</a>
        <a href="#" class="hover:text-white">Cookies</a>
        <a href="#" class="hover:text-white">Terms</a>
        <a href="#" class="hover:text-white">Sitemap</a>
      </div>

      <button class="inline-flex items-center gap-2 self-start lg:self-auto bg-white/5 border border-white/10 text-[13px] font-medium text-white px-3.5 py-2 rounded-md hover:bg-white/10 transition-colors">
        <span aria-hidden="true" class="text-base leading-none">🇦🇪</span>
        English
        <Icon name="lucide:chevron-down" class="h-3.5 w-3.5 opacity-70" />
      </button>
    </div>
  </div>
</footer>
